<title>Мой учебный сайт</title>

<style>
:root {
  --text: #1a1a1a;
  --muted: rgba(0, 0, 0, 0.65);
  --card: rgba(255, 255, 255, 0.82);
  --card-strong: rgba(255, 255, 255, 0.9);
  --stroke: rgba(0, 0, 0, 0.08);
  --shadow: 0 16px 50px rgba(0, 0, 0, 0.14);
  --radius: 18px;
  --radius-sm: 14px;
}

* { box-sizing: border-box; }

body {
  margin: 0;
  font-family: system-ui;
  color: var(--text);
}

/* HEADER */
.header {
  position: sticky;
  top: 0;
  background: rgba(255,255,255,0.75);
  border-bottom: 1px solid var(--stroke);
}

.header__container {
  max-width:1180px;
  margin:0 auto;
  padding:28px 18px;
}

.hero {
  display:grid;
  grid-template-columns:1.2fr 0.8fr;
  gap:18px;
  align-items:center;
}

.hero__title {
  margin:0;
  text-transform:uppercase;
}

.hero__text {
  color:var(--muted);
}

.hero__badge {
  justify-self:end;
  padding:12px;
  border-radius:999px;
  border:1px solid var(--stroke);
}

/* SECTION */
.section {
  padding:26px 0;
}

.section__container {
  max-width:1180px;
  margin:0 auto;
  padding:22px;
}

.section__title {
  margin-bottom:14px;
}

/* COLORS */
.section--s1 {
  background: linear-gradient(180deg,#ffd7e4,#fff);
}
.section--s2 {
  background: radial-gradient(#ff7fb3,#ff2b7d);
}
.section--s3 {
  background: linear-gradient(180deg,#ff3b3b,#fff);
}
.section--s4 {
  background: radial-gradient(#7a0028,#fff);
}

/* CARDS */
.cards {
  display:grid;
  gap:16px;
}

.cards--layout-s1 {
  grid-template-columns:1.35fr 0.85fr;
}

/* CARD */
.card {
  border-radius:var(--radius);
  background:var(--card);
  border:1px solid var(--stroke);
  box-shadow:var(--shadow);
}

.card__top {
  display:grid;
  gap:12px;
  padding:16px;
}

.card__meta {
  display:grid;
  gap:6px;
}

.card__title {
  margin:0;
}

.card__text {
  color:rgba(0,0,0,0.7);
}

.card__image img {
  width:100%;
}

/* MINI */
.card__mini-grid {
  display:grid;
  gap:12px;
  padding:16px;
}

.mini-card {
  display:grid;
  grid-template-columns:88px 1fr;
  gap:10px;
  padding:12px;
  border-radius:var(--radius-sm);
  background:white;
}

.mini-card__image {
  width:88px;
  height:64px;
  object-fit:cover;
}

.mini-card__content {
  display:grid;
  gap:4px;
}

.mini-card__title {
  font-size:13px;
}

.mini-card__text {
  font-size:12px;
  color:rgba(0,0,0,0.65);
}

/* FOOTER */
.footer {
  background:#0f0f12;
  color:white;
}

.footer__container {
  max-width:1180px;
  margin:auto;
  padding:20px;
}
</style>
</head>
